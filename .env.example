# Copy this to `.env` and update values. Never commit your local `.env`.

# Published Docker image.
AETHERA_IMAGE=n120318/aethera
AETHERA_TAG=latest

# Host directory used for the SQLite database, cache, logs, and runtime files.
AETHERA_CONFIG_PATH=./config

# Production HTTP port exposed on the host.
AETHERA_HTTP_PORT=8173

# Host media directory mounted into the containers at /data.
AETHERA_MEDIA_PATH=./media

# Container file ownership for /config and /data.
PUID=1000
PGID=1000

# Optional one-time bootstrap. Prefer changing the password in the UI afterwards.
# AETHERA_ADMIN_PASSWORD=
