# Copy this to `.env` for source development.

# Development uses local Docker builds, but these values are also used by the
# release-style compose template when you run it from a source checkout.
AETHERA_IMAGE=n120318/aethera
AETHERA_TAG=latest
AETHERA_CONFIG_PATH=./config
AETHERA_HTTP_PORT=8173
AETHERA_MEDIA_PATH=./media

# Container file ownership for /config and /data.
PUID=1000
PGID=1000

# Development runtime.
# Set AETHERA_DEV_HOT_RELOAD=0 to keep source mounts but run backend with
# multiple workers and frontend from a built preview bundle.
AETHERA_DEV_HOT_RELOAD=1
AETHERA_DEV_BACKEND_MODE=dev
AETHERA_DEV_UVICORN_WORKERS=4

# Development service ports.
AETHERA_DEV_BACKEND_PORT=8001
AETHERA_DEV_FRONTEND_PORT=8173
AETHERA_SQLITE_WEB_PORT=8081

# Optional one-time bootstrap. Prefer changing the password in the UI afterwards.
# AETHERA_ADMIN_PASSWORD=
